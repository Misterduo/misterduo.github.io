---
import { siteConfig } from "../config";
---

<div
  id="hero"
  class="relative isolate overflow-hidden bg-white py-24 md:h-screen"
  style={`--accent-color: ${siteConfig.accentColor}`}
>

  <div class="h-full mx-auto p-8 sm:p-12 md:p-24 flex items-center">
    <div>
      <h2
        class="text-pretty text-xl sm:text-2xl md:text-5xl font-bold tracking-tight text-gray-700 animate-fade-in"
      >
        Hello!
        <span id="cat" class="cat">🐈</span>
        <span id="meow" class="meow">meow!</span>
      </h2>

      <h1
        class="mt-6 sm:mt-8 md:mt-10 text-pretty text-4xl sm:text-5xl md:text-6xl lg:text-8xl font-bold tracking-tight text-gray-800 animate-fade-in animation-delay-200"
      >
        I'm
        <span style={{ color: siteConfig.accentColor }}>
          {siteConfig.name}
        </span>
      </h1>

      <p
        class="mt-4 sm:mt-6 md:mt-8 text-pretty text-base sm:text-lg md:text-xl/8 font-medium text-gray-600 animate-fade-in animation-delay-400"
      >
        {siteConfig.title}
      </p>
    </div>
  </div>

</div>

<style>

.cat {
  cursor: pointer;
  display: inline-block;
  margin-left: 8px;
  font-size: 1.2em;
  transform-origin:center bottom;
  user-select: none;
  position: relative;
  touch-action: none;
}

.cat-wiggle {
  animation: wiggle 0.3s ease;
}

@keyframes wiggle {
  0% { transform: rotate(0deg); }
  25% { transform: rotate(-20deg); }
  50% { transform: rotate(20deg); }
  75% { transform: rotate(-10deg); }
  100% { transform: rotate(0deg); }
}

.cat-falling {
  position: fixed;
  left: 50%;
  transform: translateX(-50%);
  animation: catFall 1.4s cubic-bezier(.2,.8,.2,1) forwards;
}

.cat-walk {
  animation: catStep 0.35s ease-in-out infinite;
}

@keyframes catStep {

  0% {
    transform: translateY(0) scaleX(var(--dir));
  }

  50% {
    transform: translateY(-4px) scaleX(var(--dir));
  }

  100% {
    transform: translateY(0) scaleX(var(--dir));
  }

}

@keyframes catFall {

  0% {
    top: 20%;
    transform: translateX(-50%) rotate(0deg);
  }

  70% {
    top: calc(100vh - 80px);
    transform: translateX(-50%) rotate(180deg);
  }

  85% {
    top: calc(100vh - 120px);
    transform: translateX(-50%) rotate(200deg);
  }

  100% {
    top: calc(100vh - 60px);
    transform: translateX(-50%) rotate(180deg);
  }

}

.meow {
  opacity: 0;
  margin-left: 10px;
  font-size: 14px;
  color: gray;
  transition: opacity 0.2s;
}

.meow-show {
  opacity: 1;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.animate-fade-in {
  animation: fadeIn 0.8s ease-out forwards;
  opacity: 0;
}

.animation-delay-200 {
  animation-delay: 0.2s;
}

.animation-delay-400 {
  animation-delay: 0.4s;
}

.animation-delay-600 {
  animation-delay: 0.6s;
}

</style>

<script>
(() => {
  let clicks = 0;
  let broken = false;
  let landed = false;
  let walking = false;
  let dragging = false;
  let dragTimeout = null;

  const cat = document.getElementById("cat");
  const meow = document.getElementById("meow");

  if (!cat) return;

  // CLICK BEHAVIOR (before broken)
  cat.addEventListener("click", () => {
    if (broken) return;

    clicks++;
    // wiggle
    cat.classList.add("cat-wiggle");
    setTimeout(() => cat.classList.remove("cat-wiggle"), 300);

    // meow bubble
    if (meow) {
      meow.classList.add("meow-show");
      setTimeout(() => meow.classList.remove("meow-show"), 600);
    }

    if (clicks >= 5) breakCat();
  });

  // DETACH + LOCK SIZE then FALL
  function breakCat() {
    broken = true;

    const rect = cat.getBoundingClientRect();

    // lock the computed size and font-size (pixel-perfect)
    const cs = window.getComputedStyle(cat);
    cat.style.width = rect.width + "px";
    cat.style.height = rect.height + "px";
    cat.style.fontSize = cs.fontSize;
    cat.style.lineHeight = cs.lineHeight;

    // move out of heading into body so layout won't reflow it
    document.body.appendChild(cat);

    // make it fixed at the exact pixel position of the original element
    cat.style.position = "fixed";
    cat.style.left = rect.left + "px"; // left edge in px
    cat.style.top = rect.top + "px";
    cat.style.zIndex = 9999;
    cat.style.pointerEvents = "auto";
    cat.style.transform = ""; // clear wiggle transforms

    // begin falling physics
    fallPhysics();
  }

  // FALLING WITH BOUNCE (JS physics loop)
  function fallPhysics() {
    let velocity = 0;
    const gravity = 1.6;      // tweak for heavier or lighter fall
    const bounceFactor = 0.45; // how much velocity is kept after bounce
    const minBounceVelocity = 6; // threshold to stop bouncing

    function step() {
      if (landed) return; // safety

      const rect = cat.getBoundingClientRect();
      velocity += gravity;

      let newTop = rect.top + velocity;
      const floor = window.innerHeight - rect.height; // top coordinate where paws touch

      if (newTop >= floor) {
        // Land or bounce
        newTop = floor;
        // If bounce small, stop and finalize landing
        if (Math.abs(velocity) <= minBounceVelocity) {
          cat.style.top = floor + "px";
          finalizeLanding();
          return;
        } else {
          // bounce up
          velocity = -velocity * bounceFactor;
          cat.style.top = newTop + "px";
          requestAnimationFrame(step);
          return;
        }
      }

      cat.style.top = newTop + "px";
      requestAnimationFrame(step);
    }

    requestAnimationFrame(step);
  }

  // finalize landing; wait then start walking
  function finalizeLanding() {
    landed = true;
    // ensure exact paws-on-bottom placement
    const rect = cat.getBoundingClientRect();
    cat.style.top = (window.innerHeight - rect.height) + "px";
    // flip vertically so cat faces up (optional style)
    // cat.style.transform = "rotate(180deg)"; // don't rotate vertically, we use scaleX when walking

    // enable dragging immediately
    enableDragging();

    // after a short pause start walking
    setTimeout(() => {
      if (!dragging) startWalking();
    }, 2000);
  }

function startWalking() {

  if (walking) return
  walking = true

  const speed = 1.6
  let direction = Math.random() < 0.5 ? -1 : 1

  let posX = cat.getBoundingClientRect().left

  function step() {

    if (!walking || dragging) {
      requestAnimationFrame(step)
      return
    }

    const rect = cat.getBoundingClientRect()

    const leftEdge = 0
    const rightEdge = window.innerWidth - rect.width

    posX += direction * speed

    // LEFT EDGE
    if (posX <= leftEdge) {
      posX = leftEdge
      direction = 1
    }

    // RIGHT EDGE
    if (posX >= rightEdge) {
      posX = rightEdge
      direction = -1
    }

    // random direction change (rare)
    if (Math.random() < 0.002) {
      direction *= -1
    }

    // face direction
    // set direction variable for animation
    cat.style.setProperty("--dir", direction === 1 ? -1 : 1)

    // ensure walking animation is active
    cat.classList.add("cat-walk")

    cat.style.left = posX + "px"

    requestAnimationFrame(step)

  }

  requestAnimationFrame(step)

}

  // DRAGGING: pointer-based for mouse & touch
  function enableDragging() {
    let startX = 0;
    let startY = 0;
    let startLeft = 0;
    let startTop = 0;

    function clampPosition(left, top, width, height) {
      // Keep within viewport horizontally; vertically we allow anywhere but keep paws visible as preferred
      const minLeft = 0;
      const maxLeft = Math.max(0, window.innerWidth - width);
      const clampedLeft = Math.max(minLeft, Math.min(maxLeft, left));
      const minTop = 0;
      const maxTop = Math.max(0, window.innerHeight - height);
      const clampedTop = Math.max(minTop, Math.min(maxTop, top));
      return { left: clampedLeft, top: clampedTop };
    }

    function onPointerDown(e) {
      e.preventDefault();
      dragging = true;
      walking = false; // pause walking while dragging
      cat.setPointerCapture?.(e.pointerId);

      const rect = cat.getBoundingClientRect();
      startX = e.clientX;
      startY = e.clientY;
      startLeft = rect.left;
      startTop = rect.top;

      cat.style.cursor = "grabbing";
      // cancel any automatic restart
      if (dragTimeout) { clearTimeout(dragTimeout); dragTimeout = null; }
    }

    function onPointerMove(e) {
      if (!dragging) return;
      const dx = e.clientX - startX;
      const dy = e.clientY - startY;
      const rect = cat.getBoundingClientRect();
      const width = rect.width, height = rect.height;
      const rawLeft = startLeft + dx;
      const rawTop = startTop + dy;
      const clamped = clampPosition(rawLeft, rawTop, width, height);
      cat.style.left = clamped.left + "px";
      cat.style.top = clamped.top + "px";
      cat.style.bottom = "auto";
    }

    function onPointerUp(e) {
      if (!dragging) return;
      dragging = false;
      cat.releasePointerCapture?.(e.pointerId);
      cat.style.cursor = "grab";
      // resume walking after short delay if landed
      if (landed) {
        if (dragTimeout) clearTimeout(dragTimeout);
        dragTimeout = setTimeout(() => {
          if (!dragging) startWalking();
        }, 900);
      }
    }

    // attach pointer events to cat and document
    cat.addEventListener("pointerdown", onPointerDown);
    window.addEventListener("pointermove", onPointerMove);
    window.addEventListener("pointerup", onPointerUp);

    // keep cat inside bounds on resize
    window.addEventListener("resize", () => {
      const r = cat.getBoundingClientRect();
      const minLeft = 0;
      const maxLeft = Math.max(0, window.innerWidth - r.width);
      const clampedLeft = Math.max(minLeft, Math.min(maxLeft, r.left));
      if (Math.abs(clampedLeft - r.left) > 0.5) {
        cat.style.left = clampedLeft + "px";
      }
      // ensure bottom placement if landed
      if (landed) {
        cat.style.top = (window.innerHeight - r.height) + "px";
      }
    }, { passive: true });
  }

})();
</script>